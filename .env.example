# Delta Sharing connection profile
# config.json is already present in the repo root with your bearer token — leave as-is.
# Ask the organizers if your token has expired or if you get a 401 error.
DELTA_SHARING_PROFILE=config.json

# Maximum number of rows to load per table (default: 1000).
# Set to 0 or leave blank to load all rows.
DELTA_SHARING_LIMIT=1000

# Collibra REST API (Semantic Layer)
# Organizers will distribute COLLIBRA_USERNAME and COLLIBRA_PASSWORD at kickoff.
COLLIBRA_BASE_URL=https://next.collibra.com
COLLIBRA_USERNAME=your_username
COLLIBRA_PASSWORD=your_password
